{
  "name": "ai-chat-bot-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "cd packages/web && npm run dev",
    "dev:api": "cd packages/server && .venv/bin/python -m uvicorn app.main:app --reload --port 8000",
    "build:web": "cd packages/web && npm run build"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
