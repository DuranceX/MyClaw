# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/src/web/node_modules
/packages/web/node_modules
/src/web/.pnp
.pnp.*
/src/web/.yarn/*
!/src/web/.yarn/patches
!/src/web/.yarn/plugins
!/src/web/.yarn/releases
!/src/web/.yarn/versions
.package-lock.json
.pnpm-lock.yaml
/src/web/package-lock.json
/src/web/pnpm-lock.yaml


# testing
/src/web/coverage

# next.js
/src/web/.next/
/src/web/out/
/packages/web/.next/
/packages/web/out/

# production
/src/web/build
/packages/web/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
/packages/web/.env*
/packages/server/.env*
!.env.example
!/packages/web/.env.example
!/packages/server/.env.example

# python
/packages/server/.venv/
__pycache__/
*.pyc

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.chat-sessions/
